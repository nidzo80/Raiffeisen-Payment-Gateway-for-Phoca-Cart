<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="pcp" method="upgrade" version="3">
    <name>plg_pcp_raiaccept</name>
    <creationDate>2026-03-18</creationDate>
    <author>Nikola Đurić</author>
    <authorEmail>info@lenix.rs/authorEmail>
    <copyright>Copyright (C) 2026. All rights reserved.</copyright>
    <license>GNU General Public License version 3 or later</license>
    <version>1.0.0</version>
    <description>PLG_PCP_RAIACCEPT_XML_DESCRIPTION</description>
    <namespace path="src">YourVendor\Plugin\Pcp\RaiAccept</namespace>

    <scriptfile>install.php</scriptfile>

    <languages folder="language">
        <language tag="en-GB">en-GB/plg_pcp_raiaccept.ini</language>
        <language tag="en-GB">en-GB/plg_pcp_raiaccept.sys.ini</language>
    </languages>

    <files>
        <folder>services</folder>
        <folder plugin="raiaccept">src</folder>
    </files>

    <form>
        <fields name="params" addfieldpath="/administrator/components/com_phocacart/models/fields">
            <fieldset name="payment" group="pcp">

                <!-- Sandbox mod -->
                <field name="sandbox"
                       type="list"
                       label="PLG_PCP_RAIACCEPT_FIELD_SANDBOX_LABEL"
                       description="PLG_PCP_RAIACCEPT_FIELD_SANDBOX_DESC"
                       default="1"
                >
                    <option value="1">PLG_PCP_RAIACCEPT_YES</option>
                    <option value="0">PLG_PCP_RAIACCEPT_NO</option>
                </field>

                <!-- Statusi ordera -->
                <field name="phocahead_statuses"
                       type="phocahead"
                       default="PLG_PCP_RAIACCEPT_FIELD_SPACER_STATUSES_LABEL"
                       label=""
                       description=""
                       filter="unset"
                />

                <field name="status_completed"
                       type="PhocaCartOrderStatus"
                       default="6"
                       label="PLG_PCP_RAIACCEPT_FIELD_STATUS_COMPLETED_LABEL"
                       description="PLG_PCP_RAIACCEPT_FIELD_STATUS_COMPLETED_DESC"
                />

                <field name="status_failed"
                       type="PhocaCartOrderStatus"
                       default="7"
                       label="PLG_PCP_RAIACCEPT_FIELD_STATUS_FAILED_LABEL"
                       description="PLG_PCP_RAIACCEPT_FIELD_STATUS_FAILED_DESC"
                />

                <field name="status_canceled"
                       type="PhocaCartOrderStatus"
                       default="3"
                       label="PLG_PCP_RAIACCEPT_FIELD_STATUS_CANCELED_LABEL"
                       description="PLG_PCP_RAIACCEPT_FIELD_STATUS_CANCELED_DESC"
                />

                <field name="status_refunded"
                       type="PhocaCartOrderStatus"
                       default="5"
                       label="PLG_PCP_RAIACCEPT_FIELD_STATUS_REFUNDED_LABEL"
                       description="PLG_PCP_RAIACCEPT_FIELD_STATUS_REFUNDED_DESC"
                />

                <field name="status_part_refunded"
                       type="PhocaCartOrderStatus"
                       default="5"
                       label="PLG_PCP_RAIACCEPT_FIELD_STATUS_PART_REFUNDED_LABEL"
                       description="PLG_PCP_RAIACCEPT_FIELD_STATUS_PART_REFUNDED_DESC"
                />

                <!-- API Kredencijali -->
                <field name="phocahead_api"
                       type="phocahead"
                       default="PLG_PCP_RAIACCEPT_FIELD_SPACER_API_LABEL"
                       label=""
                       description=""
                       filter="unset"
                />

                <field name="api_username"
                       type="text"
                       label="PLG_PCP_RAIACCEPT_FIELD_API_USERNAME_LABEL"
                       description="PLG_PCP_RAIACCEPT_FIELD_API_USERNAME_DESC"
                       required="true"
                />

                <field name="api_password"
                       type="password"
                       label="PLG_PCP_RAIACCEPT_FIELD_API_PASSWORD_LABEL"
                       description="PLG_PCP_RAIACCEPT_FIELD_API_PASSWORD_DESC"
                       required="true"
                />

            </fieldset>
        </fields>
    </form>

</extension>
